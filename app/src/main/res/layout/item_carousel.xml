<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <CheckBox android:id="@+id/c_check"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:buttonTint="@color/brand_orange"
        android:checked="true" />

    <TextView android:id="@+id/c_index"
        android:layout_width="32dp" android:layout_height="wrap_content"
        android:textColor="@color/brand_accent"
        android:textStyle="bold"
        android:textSize="14sp"
        android:gravity="center" />

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="6dp">

        <TextView android:id="@+id/c_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="14sp"
            android:textStyle="bold" android:maxLines="2" android:ellipsize="end" />

        <TextView android:id="@+id/c_meta"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="11sp"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
