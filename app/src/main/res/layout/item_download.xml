<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@color/bg_surface"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:id="@+id/dl_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="14sp"
            android:textStyle="bold" android:singleLine="true" android:ellipsize="end" />

        <TextView android:id="@+id/dl_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/brand_accent" android:textSize="12sp"
            android:paddingTop="2dp" />

        <TextView android:id="@+id/dl_sub"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="11sp"
            android:singleLine="true" android:ellipsize="middle" android:paddingTop="2dp" />
    </LinearLayout>

    <ImageButton android:id="@+id/dl_play"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="play"
        android:visibility="gone" />
</LinearLayout>
