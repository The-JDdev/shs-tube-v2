<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@color/bg_surface"
    android:layout_marginVertical="4dp">
    <TextView android:id="@+id/t_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/text_primary" android:textSize="14sp"
        android:textStyle="bold" android:singleLine="true" android:ellipsize="end" />
    <TextView android:id="@+id/t_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/brand_accent" android:textSize="12sp"
        android:paddingTop="2dp" />
    <TextView android:id="@+id/t_info"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/text_muted" android:textSize="11sp"
        android:paddingTop="2dp" />
</LinearLayout>
