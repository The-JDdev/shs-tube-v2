<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="back" />

        <ImageButton android:id="@+id/btn_forward"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="forward" />

        <ImageButton android:id="@+id/btn_reload"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_reload"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="reload" />

        <EditText android:id="@+id/url_bar"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="@string/hint_url"
            android:singleLine="true"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:background="@color/bg_elevated"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <ImageButton android:id="@+id/btn_go"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="go" />

        <FrameLayout
            android:layout_width="44dp" android:layout_height="44dp">
            <ImageButton android:id="@+id/btn_downloads"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_download"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="downloads" />
            <TextView android:id="@+id/download_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/badge_bg"
                android:paddingHorizontal="6dp" android:paddingVertical="1dp"
                android:textColor="@color/white" android:textSize="10sp"
                android:visibility="gone" tools:ignore="MissingDefaultResource"
                xmlns:tools="http://schemas.android.com/tools" />
        </FrameLayout>

        <ImageButton android:id="@+id/btn_browser_settings"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="settings" />
    </LinearLayout>

    <WebView android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
